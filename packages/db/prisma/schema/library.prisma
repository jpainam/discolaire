model Book {
    id            Int               @id @default(autoincrement())
    title         String
    description   String?
    year          Int?
    author        String
    isbn          String?
    publishedAt   DateTime?
    lastBorrowed  DateTime?
    tags          String[]
    schoolId      String
    createdAt     DateTime          @default(now())
    updatedAt     DateTime          @updatedAt
    categoryId    String
    copies        Int               @default(1)
    category      BookCategory      @relation(fields: [categoryId], references: [id])
    loans        BookLoan[]
    reservations BookReservation[]

    @@unique([isbn, schoolId])
}

model BookCategory {
    id       String @id @default(cuid())
    name     String
    schoolId String
    books    Book[]

    @@unique([name, schoolId])
}

model BookLoan {
    id          Int       @id @default(autoincrement())
    bookId      Int
    studentId   String?
    staffId     String?
    contactId   String?
    createdById String?
    borrowed    DateTime  @default(now())
    returned    DateTime?
    expected    DateTime?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    book        Book      @relation(fields: [bookId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    student     Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
    staff       Staff?    @relation(fields: [staffId], references: [id], onDelete: SetNull)
    contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
    createdBy   User?     @relation("BookLoanCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
}

enum ReservationStatus {
    PENDING
    CONFIRMED
    CANCELLED
    FULFILLED
}

model BookReservation {
    id         Int               @id @default(autoincrement())
    bookId     Int
    studentId   String?
    staffId     String?
    contactId   String?
    createdById String?
    reservedAt  DateTime          @default(now())
    expiresAt  DateTime?
    status     ReservationStatus @default(PENDING)
    schoolId   String
    createdAt  DateTime          @default(now())
    updatedAt  DateTime          @updatedAt
    book       Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
    student     Student?          @relation(fields: [studentId], references: [id], onDelete: SetNull)
    staff       Staff?            @relation(fields: [staffId], references: [id], onDelete: SetNull)
    contact     Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
    createdBy   User?             @relation("BookReservationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

    @@index([schoolId])
    @@index([bookId])
}

model Shortcut {
    id        Int      @id @default(autoincrement())
    title     String
    url       String
    userId    String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    schoolId  String

    @@unique([userId, url, schoolId])
    @@index([userId, schoolId])
}
